# Copy this file to backend/.env and fill in your values

# The Blue Alliance API key – get one at https://www.thebluealliance.com/account
TBA_API_KEY=your_tba_api_key_here

# Number of consecutive frames a track must be absent before a re-ID prompt fires
REIDENTIFY_THRESHOLD_FRAMES=30

# FastAPI server settings
HOST=0.0.0.0
PORT=8000
